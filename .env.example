# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Site URL ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Payment Provider (Yoco) ────────────────────────────────────
# Get keys from https://dashboard.yoco.com
PAYMENT_PROVIDER=yoco
PAYMENT_SECRET_KEY=sk_test_...
PAYMENT_WEBHOOK_SECRET=whsec_...

# ── Admin ──────────────────────────────────────────────────────
# Comma-separated list of admin emails
ADMIN_EMAIL_ALLOWLIST=you@yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Must be a verified sender domain in your Resend dashboard
RESEND_FROM_EMAIL=The Dexarium <orders@yarik3d.co.za>

# ── ISR Revalidation (server-to-server) ───────────────────────
REVALIDATE_SECRET=change-me-in-production

# ── E2E Testing (Playwright) ───────────────────────────────────
# Unlock authenticated admin workflow tests (admin.spec.ts)
TEST_ADMIN_EMAIL=your-admin@example.com
TEST_ADMIN_PASSWORD=your-admin-password

# Unlock authenticated user account tests (user.spec.ts)
TEST_USER_EMAIL=your-user@example.com
TEST_USER_PASSWORD=your-user-password
